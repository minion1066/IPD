# Environment variables required for use with K3s
# - FORGE_DB_HOST:    used in forgedb.py
# - OLLAMA_HOST:      used in ollama_agent.py
# - OLLAMA_HOST_0/1:  used in config.py; episodic_ipd_game.py
# - OLLAMA_PORT:      used in ollama_agent.py
# Usage: source forge_k3s.env

export FORGE_DB_HOST=platinum
export OLLAMA_HOST=tungsten
export OLLAMA_HOST_0=tungsten
export OLLAMA_HOST_1=tungsten
export OLLAMA_PORT=11435